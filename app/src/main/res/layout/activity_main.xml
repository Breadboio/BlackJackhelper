<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:text="🃏"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Blackjack Advisor"
            android:textColor="#F0E6D3"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="Perfect basic strategy, always"
            android:textColor="#8A7A6A"
            android:textSize="14sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:background="#1E1E2E" />

        <!-- Step 1: Overlay Permission -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 1 — Overlay Permission"
            android:textColor="#6C9EBF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_permission_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="⚠️ Overlay permission required"
            android:textColor="#E8A020"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Allows the advisor widget to float over your blackjack game."
            android:textColor="#6A6A7A"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_grant_permission"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Grant Overlay Permission"
            android:backgroundTint="#6C9EBF"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            android:background="#1E1E2E" />

        <!-- Step 2: Auto-Detect (Screen Capture) — hidden until overlay granted -->
        <LinearLayout
            android:id="@+id/auto_detect_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STEP 2 — Auto-Detect (Optional)"
                android:textColor="#6C9EBF"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_auto_detect_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Screen capture not granted — tap to enable"
                android:textColor="#8A7A6A"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Grants screen capture so the app can read card values automatically. Skip this to enter cards manually using the overlay buttons."
                android:textColor="#6A6A7A"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_enable_auto_detect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="Enable Auto-Detect"
                android:backgroundTint="#8E44AD"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp"
                android:background="#1E1E2E" />

        </LinearLayout>

        <!-- Step 3: Start/Stop -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 3 — Launch Overlay"
            android:textColor="#6C9EBF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Start the floating widget, then switch to your blackjack app. Tap the card icon to expand it. If auto-detect is enabled, tap the Auto-Detect toggle inside the overlay."
            android:textColor="#6A6A7A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_overlay_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Overlay not started"
            android:textColor="#8A7A6A"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_start_overlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="▶  Start Floating Advisor"
            android:backgroundTint="#27AE60"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_stop_overlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="⏹  Stop Advisor"
            android:backgroundTint="#E74C3C"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            android:background="#1E1E2E" />

        <!-- Strategy reference -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STRATEGY REFERENCE"
            android:textColor="#6C9EBF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="#12121E"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👊 HIT — Take another card" android:textColor="#E74C3C" android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✋ STAND — Keep your hand" android:textColor="#27AE60" android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💰 DOUBLE DOWN — Double bet, one card" android:textColor="#F39C12" android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✂️ SPLIT — Split a pair into two hands" android:textColor="#9B59B6" android:textSize="14sp" android:layout_marginBottom="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏳️ SURRENDER — Forfeit half your bet" android:textColor="#95A5A6" android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            android:text="Based on standard Vegas Strip rules: dealer stands on soft 17, double after split allowed, late surrender allowed."
            android:textColor="#4A4A5A"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
